{
  "name": "prolog-lsp",
  "description": "Language Server for Prolog",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "prolog",
        "extensions": [
          ".pl"
        ],
        "aliases": [
          "Prolog"
        ],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:prolog"
  ],
  "main": "./extension",
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
